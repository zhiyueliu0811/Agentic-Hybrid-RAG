# ========================================
# Agentic Hybrid RAG — 环境变量模板
# 复制为 .env 并填入真实值
# ========================================

# ---- LLM / DashScope (千问) ----
DASHSCOPE_API_KEY=your_dashscope_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ---- vLLM 本地推理 ----
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL_NAME=LLaMA-Factory-main/output/qwen3_lora_sft_int4

# ---- MongoDB ----
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=mydatabase
MONGO_COLLECTION_NAME=manual_text

# ---- 语义分块服务 ----
SEMANTIC_CHUNK_URL=http://0.0.0.0:6000/v1/semantic-chunks

# ---- HuggingFace 镜像 ----
HF_ENDPOINT=https://hf-mirror.com
